OPENAI_API_KEY=your_openai_api_key_here
# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Required for server-side saved notes.
# Vercel Storage/Postgres or Neon will provide this value.
POSTGRES_URL=postgres://user:password@host:5432/database
# Some providers expose DATABASE_URL instead.
DATABASE_URL=postgres://user:password@host:5432/database
# Direct/non-pooled URLs also work.
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/database
